APP_ENV=development
APP_NAME=Earth Cafe
APP_URL=https://earthcafe.wasmer.app
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=earthcafe
DB_CHARSET=utf8mb4

EMAIL_SERVICE=gmail
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_FROM=your_gmail@gmail.com
EMAIL_FROM_NAME=Earth Cafe
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls

# For Brevo SMTP, this must be a verified sender email or an authenticated domain mailbox.
BREVO_SENDER_EMAIL=no-reply@yourdomain.com

# Optional: Brevo API v3 key for campaign API integrations
BREVO_API_V3_KEY=your_brevo_api_v3_key
